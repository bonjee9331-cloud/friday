# ── FRIDAY OS — Environment Variables ───────────────────────────────────────
# Copy this to .env.local and fill in real values. Never commit .env.local.

# ── Auth (REQUIRED) ──────────────────────────────────────────────────────────
# The passphrase to unlock the FRIDAY voice screen.
# Supports comma-separated keywords: "biblical,genesis,friday"
# Voice recognition: saying any of these words unlocks the system.
FRIDAY_PASSWORD=biblical

# Random string used to salt the session token. Change this to invalidate all sessions.
FRIDAY_SESSION_SALT=friday-os-2026

# ── AI (REQUIRED) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Voice — ElevenLabs (optional — falls back to browser TTS if unset) ───────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Supabase (optional — app works in demo mode without it) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Telegram bot (optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── Legacy API protection for internal routes (optional) ─────────────────────
MANAGER_AUTH_KEY=
NEXT_PUBLIC_MANAGER_AUTH_KEY=

# ── External data feeds (optional) ───────────────────────────────────────────
NEWS_API_KEY=
OPENAI_API_KEY=
